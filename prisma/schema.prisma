// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  SALES_MANAGER
  SALES_EXECUTIVE
  SUPPORT_AGENT
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum CustomerStatus {
  LEAD
  ACTIVE
  INACTIVE
  CHURNED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  EMAIL_CAMPAIGN
  COLD_CALL
  EVENT
  OTHER
}

enum DealStage {
  QUALIFICATION
  NEEDS_ANALYSIS
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum WorkflowTriggerType {
  LEAD_CREATED
  CUSTOMER_CREATED
  DEAL_WON
  DEAL_LOST
  DEAL_STAGE_CHANGED
  TASK_OVERDUE
}

enum WorkflowActionType {
  ASSIGN_USER
  SEND_EMAIL
  NOTIFY_TEAM
  CREATE_TASK
  UPDATE_STATUS
  AI_SUMMARY
  AI_EMAIL_DRAFT
}

enum WorkflowRunStatus {
  SUCCESS
  FAILED
  PARTIAL
}

model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  status    OrganizationStatus @default(TRIAL)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  users     User[]
  customers Customer[]
  leads     Lead[]
  deals     Deal[]
  workflows Workflow[]

  @@map("organizations")
}

model User {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SALES_EXECUTIVE)
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens    RefreshToken[]
  createdCustomers Customer[]
  createdLeads     Lead[]         @relation("LeadCreatedBy")
  assignedLeads    Lead[]         @relation("LeadAssignedTo")
  createdDeals     Deal[]         @relation("DealCreatedBy")
  ownedDeals       Deal[]         @relation("DealOwner")
  createdWorkflows Workflow[]

  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  fullName    String
  email       String?
  phone       String?
  companyName String?
  status      CustomerStatus @default(LEAD)
  notes       String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  convertedFromLead Lead?
  deals             Deal[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("customers")
}

model Lead {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("LeadCreatedBy", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  convertedCustomerId String?   @unique
  convertedCustomer   Customer? @relation(fields: [convertedCustomerId], references: [id], onDelete: SetNull)

  fullName    String
  email       String?
  phone       String?
  companyName String?
  source      LeadSource @default(OTHER)
  status      LeadStatus @default(NEW)
  notes       String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, assignedToId])
  @@map("leads")
}

model Deal {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("DealCreatedBy", fields: [createdById], references: [id])

  ownerId String?
  owner   User?   @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  title             String
  value             Decimal   @db.Decimal(14, 2)
  currency          String    @default("BDT")
  stage             DealStage @default(QUALIFICATION)
  probability       Int       @default(10)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  notes             String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([organizationId])
  @@index([organizationId, stage])
  @@index([organizationId, ownerId])
  @@index([customerId])
  @@map("deals")
}

model Workflow {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  name        String
  description String?
  triggerType WorkflowTriggerType
  conditions  Json?
  isActive    Boolean @default(true)

  actions WorkflowAction[]
  runs    WorkflowRun[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([organizationId])
  @@index([organizationId, triggerType, isActive])
  @@map("workflows")
}

model WorkflowAction {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  order      Int
  actionType WorkflowActionType
  config     Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
  @@map("workflow_actions")
}

model WorkflowRun {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  status       WorkflowRunStatus
  triggerData  Json
  resultLog    Json
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([workflowId])
  @@map("workflow_runs")
}